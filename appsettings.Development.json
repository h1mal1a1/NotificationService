{
  "PostgreSql": {
    "ConnectionString": "Host=localhost;Port=5433;Database=notification_service_db;Username=postgres;Password=postgres"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "Exchange": "notifications.exchange",
    "Queue": "notifications.email",
    "RoutingKey": "notification.password-reset"
  },
  "Smtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "UseSsl": false,
    "UserName": "smtp-user",
    "Password": "smtp-password",
    "FromEmail": "noreply@example.com",
    "FromName": "Notification Service"
  },
  "Retry": {
    "MaxAttempts": 3,
    "FirstDelaySeconds": 5,
    "MaxDelaySeconds": 60,
    "BackoffMultiplier": 2.0,
    "PollIntervalSeconds": 5,
    "BatchSize": 10,
    "ProcessingTimeoutSeconds": 120
  }
}