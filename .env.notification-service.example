ASPNETCORE_ENVIRONMENT=Development

PostgreSql__ConnectionString=Host=db;Port=5432;Database=notification_service_db;Username=postgres;Password=postgres

RabbitMq__Host=rabbitmq
RabbitMq__Port=5672
RabbitMq__UserName=guest
RabbitMq__Password=guest
RabbitMq__Exchange=notifications.exchange
RabbitMq__Queue=notifications.email
RabbitMq__RoutingKey=notification.password-reset

Smtp__Host=mailpit
Smtp__Port=1025
Smtp__UseSsl=false
Smtp__UserName=
Smtp__Password=
Smtp__FromEmail=noreply@example.com
Smtp__FromName=Notification Service

Retry__MaxAttempts=3
Retry__FirstDelaySeconds=5
Retry__MaxDelaySeconds=60
Retry__BackoffMultiplier=2.0
Retry__PollIntervalSeconds=5
Retry__BatchSize=10
Retry__ProcessingTimeoutSeconds=120